  <diagram name="Page-1" id="8f1rnoJ54imUJZ3Wqrcn">
    <mxGraphModel dx="1129" dy="572" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="NBtEsrI96ws6vpRakEqm-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;" value="" vertex="1">
          <mxGeometry height="238.75" width="220" x="530" y="821.25" as="geometry" />
        </mxCell>
        <mxCell id="NBtEsrI96ws6vpRakEqm-2" parent="1" style="text;whiteSpace=wrap;html=1;align=left;fontSize=15;verticalAlign=bottom;fontStyle=1;strokeWidth=2;" value="&lt;font style=&quot;line-height: 1.3;&quot;&gt;&lt;br&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;याक्खा राईहरुको छुट्टेको वस्यौलिको कागाज् । किनाराका स्ही ललित बम् राई लिखकी नरबहादुर खालिङ सिंभुवा हाराबोटे बि.स. १९९३ चैत्र २५ गते ४ मासे स्याबं बस्ने जम्दार मान बहादुर राईलाई बम्सेवोलि स्ही गरी दिञ्या ।&lt;/font&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="740" x="69.39" y="100" as="geometry" />
        </mxCell>
        <mxCell id="NBtEsrI96ws6vpRakEqm-3" parent="1" style="text;whiteSpace=wrap;html=1;align=left;fontSize=15;verticalAlign=bottom;fontStyle=1;strokeWidth=2;" value="&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;+ यसै बंशदेखि छुट्टेयाको हाँसोकहाँको छोरा पुतुहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;पुतुहाँको बराजु सामिकहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;बायोकहाँको बराजु लांबाकहाँ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;मोरेहाँको बराजु युसोमहाँ ।।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;+ भिम राईको छोरादेखि छुटेको जेठा फुगोनहाँ सुमाहाँको माइला बाबुको छोरा ३ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;योक्तेनहाँको बराजु मुयुंहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;+ तोषाहाँको छोरादेखि छुटेको जेठा हिजु राई कान्छा षाँयाँहाँ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;जेठो बंश ( साबिक तल्लो सिङ्भुवा )&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;+ हिजु राईको छोरा धर्म राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;धर्म राईको जेठा पेंरेजु कान्छा भुड्या राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;भुड्या राईको छोरा जेठा देउकर्ना राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;कान्छा बिर्बल राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;+ बिर्बल राईको छोरा ::भात राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;:: भात राईको छोरा खेल्लुवाँहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;खेल्लुवाहाँको छोरा काबी राई&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;काबी राईको छोरा जेठा गैनन्दा कान्छा पन्धा राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;+ गैनन्दाको छोरा बलवान् ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;बलवानको-४ छोराहरु&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;१. रनजं (भिरमुनि)&amp;nbsp; &amp;nbsp; &amp;nbsp;२. खपनसिङ् (हिटीघर-फतुरेजग्गा)&amp;nbsp; &amp;nbsp; &amp;nbsp;३.&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;font-size: 16px; background-color: transparent;&quot;&gt;पुुनुकसिङ् (लामाटोले)&lt;/span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;४. आसाराम (&lt;/span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;थोयङ&lt;/span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;)&lt;/span&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;+ पन्धा राईको छोरा कान्छा अम्बसिङ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;अम्बसिङ् (अम्बोटे) को छोरा दर्क राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;दर्क राईको २ भाइ छोराहरु&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;१. हर्कबहादुर&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; २. पृथिमान (ढेबा राईको बाबु ) ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;+ कान्छो बंश (साबिक माथिल्लो सिङ्भुवा)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;षाँयाँहाँको ४ भाई छोराहरु&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px; color: rgb(0, 0, 0);&quot;&gt;१. पाँगेहाँ&amp;nbsp; &amp;nbsp; &amp;nbsp;२. नाम्घोनहाँ&amp;nbsp; &amp;nbsp; &amp;nbsp;३. माँगुहाँ&amp;nbsp; &amp;nbsp; &amp;nbsp;४. याबोकहाँ&amp;nbsp;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="692.5" width="770.61" x="69.39" y="130" as="geometry" />
        </mxCell>
