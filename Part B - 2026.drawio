        <mxCell id="NBtEsrI96ws6vpRakEqm-2" parent="1" style="text;whiteSpace=wrap;html=1;align=left;fontSize=15;verticalAlign=bottom;fontStyle=1;strokeWidth=2;" value="&lt;font style=&quot;line-height: 1.3;&quot;&gt;&lt;br&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;याक्खा राईहरुको छुट्टेको वस्यौलिको कागाज् । किनाराका स्ही ललित बम् राई लिखकी नरबहादुर खालिङ सिंभुवा हाराबोटे बि.स. १९९३ चैत्र २५ गते ४ मासे स्याबं बस्ने जम्दार मान बहादुर राईलाई बम्सेवोलि स्ही गरी दिञ्या ।&lt;/font&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="740" x="69.39" y="100" as="geometry" />
        </mxCell>
        <mxCell id="NBtEsrI96ws6vpRakEqm-3" parent="1" style="text;whiteSpace=wrap;html=1;align=left;fontSize=15;verticalAlign=bottom;fontStyle=1;strokeWidth=2;" value="&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;+ यसै बंशदेखि छुट्टेयाको हाँसोकहाँको छोरा पुतुहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;पुतुहाँको बराजु सामिकहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;बायोकहाँको बराजु लांबाकहाँ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;मोरेहाँको बराजु युसोमहाँ ।।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;+ भिम राईको छोरादेखि छुटेको जेठा फुगोनहाँ सुमाहाँको माइला बाबुको छोरा ३ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;योक्तेनहाँको बराजु मुयुंहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;+ तोषाहाँको छोरादेखि छुटेको जेठा हिजु राई कान्छा षाँयाँहाँ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;जेठो बंश ( साबिक तल्लो सिङ्भुवा )&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;+ हिजु राईको छोरा धर्म राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;धर्म राईको जेठा पेंरेजु कान्छा भुड्या राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;भुड्या राईको छोरा जेठा देउकर्ना राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;कान्छा बिर्बल राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;+ बिर्बल राईको छोरा ::भात राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;:: भात राईको छोरा खेल्लुवाँहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;खेल्लुवाहाँको छोरा काबी राई&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;काबी राईको छोरा जेठा गैनन्दा कान्छा पन्धा राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;+ गैनन्दाको छोरा बलवान् ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;बलवानको-४ छोराहरु&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;१.रनजं (भिरमुनि)&amp;nbsp; &amp;nbsp; &amp;nbsp;२.खपनसिङ्(हिटीघर-फतुरेजग्गा)&amp;nbsp; &amp;nbsp; &amp;nbsp;३.&lt;/font&gt;&lt;span style=&quot;font-size: 16px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;पुुनुकसिङ्(लामाटोले)&lt;/span&gt;&lt;span style=&quot;font-size: 16px;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;font-size: 16px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;४.आसाराम(सिङ्बोले)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;+ पन्धा राईको छोरा कान्छा अम्बसिङ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;अम्बसिङ् (अम्बोटे) को छोरा दर्क राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;दर्क राईको २ भाइ छोराहरु&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;१. हर्कबहादुर&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; २.पृथिमान (ढेबा राईको बाबु ) ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;+ कान्छो बंश (साबिक माथिल्लो सिङ्भुवा)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;षाँयाँहाँको ४ भाई छोराहरु&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;१. पाँगेहाँ&amp;nbsp; &amp;nbsp; &amp;nbsp;२. नाम्घोनहाँ&amp;nbsp; &amp;nbsp; &amp;nbsp;३. माँगुहाँ&amp;nbsp; &amp;nbsp; &amp;nbsp;४. याबोकहाँ&amp;nbsp;&lt;/font&gt;&lt;/div&gt;" vertex="1">
