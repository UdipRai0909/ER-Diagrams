        <mxCell id="tguNu68QVx0lC-mZnvX6-55" parent="1" style="text;whiteSpace=wrap;html=1;align=left;fontSize=15;verticalAlign=bottom;fontStyle=1;strokeWidth=2;" value="&lt;font style=&quot;line-height: 1.3;&quot;&gt;&lt;br&gt;&lt;span style=&quot;font-size: 21px;&quot;&gt;याक्खा राईहरुको छुट्टेको वस्यौलिको कागाज् । किनाराका स्ही ललित बम् राई लिखकी नरबहादुर खालिङ सिंभुवा हाराबोटे बि.स. १९९३ चैत्र २५ गते ४ मासे स्याबं बस्ने जम्दार मान बहादुर राईलाई बम्सेवोलि स्ही गरी दिञ्या ।&lt;/span&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="972.07" x="111.73000000000002" y="9970" as="geometry" />
        </mxCell>
        <mxCell id="tguNu68QVx0lC-mZnvX6-56" parent="1" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=15;fontStyle=1;strokeWidth=2;" value="&lt;div style=&quot;text-align: left&quot;&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="20" x="595.2800000000002" y="10125" as="geometry" />
        </mxCell>
        <mxCell id="tguNu68QVx0lC-mZnvX6-57" parent="1" style="text;whiteSpace=wrap;html=1;align=left;fontSize=15;verticalAlign=bottom;fontStyle=1;strokeWidth=2;" value="&lt;div&gt;&lt;div&gt;&lt;font&gt;+ यसै बंशदेखि छुट्टेयाको हाँसोकहाँको छोरा पुतुहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;पुतुहाँको बराजु सामिकहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;बायोकहाँको बराजु लांबाकहाँ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;मोरेहाँको बराजु युसोमहाँ ।।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;+ भिम राईको छोरादेखि छुटेको जेठा फुगोनहाँ सुमाहाँको माइला बाबुको छोरा ३ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;योक्तेनहाँको बराजु मुयुंहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;+ तोषाहाँको छोरादेखि छुटेको जेठा हिजु राई कान्छा षाँयाँहाँ ।।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;जेठो बंश ( साबिक तल्लो सिङ्भुवा )&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;+ हिजु राईको छोरा धर्म राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;धर्म राईको जेठा पेंरेजु कान्छा भुड्या राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;भुड्या राईको छोरा जेठा देउकर्ना राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;कान्छा बिर्बल राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;+ बिर्बल राईको छोरा ::भात राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;:: भात राईको छोरा खेल्लुवाँहाँ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;खेल्लुवाहाँको छोरा काबी राई&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;काबी राईको छोरा जेठा गैनन्दा कान्छा पन्धा राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;+ गैनन्दाको छोरा बलवान् ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;बलवानको-४ छोराहरु १.रनजं (भिरमुनि) २.खपनसिङ्(हिटीघर-फतुरेजग्गा) ३.&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;पुुनुकसिङ्(लामाटोले)४.आसाराम(सिङ्बोले) ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;+ पन्धा राईको छोरा कान्छा अम्बसिङ ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;अम्बसिङ् (अम्बोटे) को छोरा दर्क राई ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;दर्क राईको २ भाइ छोराहरु १. हर्कबहादुर २.पृथिमान (ढेबा राईको बाबु ) ।&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;+ कान्छो बंश (साबिक माथिल्लो सिङ्भुवा)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;षाँयाँहाँको ४ भाई छोराहरु&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font&gt;१. पाँगेहाँ २. नाम्घोनहाँ ३. माँगुहाँ ४. याबोकहाँ&amp;nbsp;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
